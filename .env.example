# Supabase Project Configuration
# Copy this file to .env and replace the placeholder values with your actual
# keys from your Supabase project dashboard → Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Authentication Redirect URL
# Set this to your production URL (e.g., https://app-zeta-five-90.vercel.app)
# If not set, it will default to the current window.location.origin
VITE_AUTH_REDIRECT_URL=https://your-production-url.com
